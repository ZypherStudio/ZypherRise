{
  "name": "zypherrise-launcher",
  "productName": "ZypherRise",
  "version": "1.1.1",
  "description": "ZypherRise | Next-Gen Minecraft Experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder -p always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "minecraft-launcher-core": "^3.2.2",
    "msmc": "^3.1.2",
    "skinview3d": "^3.4.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.zypherrise.launcher",
    "productName": "ZypherRise",
    "copyright": "Copyright © 2026 Zypher Studio",
    "directories": {
      "output": "../dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ZypherStudio",
        "repo": "ZypherRise"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../assets/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../assets/logo.png",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
